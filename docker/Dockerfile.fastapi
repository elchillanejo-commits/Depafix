FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
COPY core/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || pip install fastapi uvicorn psycopg2-binary pyjwt requests jinja2 aiofiles python-multipart
COPY core/ .
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
HEALTHCHECK --interval=30s --timeout=5s CMD curl -f http://localhost:8000/ || exit 1
