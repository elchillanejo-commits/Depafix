# Copiar a .env (gitignored) y completar con los valores reales.
# NUNCA commitear .env ni pegar estas claves en código, logs o chats.

# Supabase -- Settings > API en el dashboard del proyecto.
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave "anon" (pública, RLS la limita). La usa DatabaseManager.get_client(),
# que es lo que usa todo el proyecto por defecto para lecturas.
SUPABASE_KEY=

# Clave "service_role" (bypassea RLS -- server-side únicamente, nunca en
# nada que sirva una request de un cliente/frontend). La usa
# DatabaseManager.get_service_client(), necesaria para las escrituras de
# auditoría (operaciones_ejecutadas, alertas_precio_serviu, salud_agentes).
SUPABASE_SERVICE_ROLE_KEY=
